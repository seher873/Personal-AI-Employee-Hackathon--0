# Gold Tier MCP Servers - Environment Variables
# Copy this file to .env and fill in your credentials

# ============================================
# Facebook Credentials
# ============================================
FB_EMAIL=your-facebook-email@example.com
FB_PASSWORD=your-facebook-password-here

# Facebook API Credentials (for API-based posting)
FB_ACCESS_TOKEN=your_facebook_access_token_here
FB_PAGE_ID=your_facebook_page_id_here

# ============================================
# Instagram Credentials
# ============================================
IG_USERNAME=your-instagram-username
IG_PASSWORD=your-instagram-password-here

# Instagram API Credentials (for API-based posting)
IG_ID=your_instagram_business_account_id_here

# ============================================
# Twitter/X Credentials
# ============================================
TWITTER_EMAIL=your-twitter-email@example.com
TWITTER_PASSWORD=your-twitter-password-here


GMAIL_EMAIL=your-gmail-email@gmail.com
GMAIL_PASSWORD=your-gmail-password-here

# ============================================
# WhatsApp Credentials (optional)
# ============================================
WHATSAPP_PHONE=your_whatsapp_phone_number_id
WHATSAPP_API_KEY=your_whatsapp_api_key

# ============================================
# MCP Server Configuration
# ============================================
# Social MCP Server Port (Node.js)
MCP_PORT=3000

# Audit MCP Server Port (Python)
AUDIT_MCP_PORT=3001
