# Silver Tier - Environment Variables

# Gmail
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# WhatsApp (QR code login - no credentials needed)

LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password-here


# MCP Server Configuration
# ============================================
# Social MCP Server Port (Node.js)
MCP_PORT=3000

# Audit MCP Server Port (Python)
AUDIT_MCP_PORT=3001

# AI/LLM (Optional)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
